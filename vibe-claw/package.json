{
  "name": "vibe-claw",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "check": "npm run build && npm run test",
    "db:setup:local": "bash scripts/db-local-setup.sh",
    "db:migrate": "tsx scripts/db-migrate.ts",
    "dev:db": "bash scripts/dev-db.sh",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:verify": "tsx scripts/db-verify.ts",
    "verify": "npm run lint && npm run typecheck && npm run build && npm test && npm run db:verify"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "fastify": "^5.2.1",
    "pg": "^8.20.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.20.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
